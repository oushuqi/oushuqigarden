<footer class="site-footer">
  <div class="footer-content">
    <p class="footer-quote">「生命是一场奇旅，我希望你永远超级幸福。」</p>
    <p class="footer-meta">© {{ meta.siteName or 'My Site' }} · All rights reserved.</p>
    <a href="#" class="back-to-top">返回顶部 ↑</a>
  </div>

  <!-- ✨ 小星星们（位置和延迟可随意调） -->
  <span class="star" style="top:20px; left:15%; animation-delay: 1s;">✨</span>
  <span class="star" style="top:50px; right:20%; animation-delay: 2s;">✨</span>
  <span class="star" style="bottom:30px; left:25%; animation-delay: 3s;">✨</span>
  <span class="star" style="bottom:40px; right:15%; animation-delay: 1.5s;">✨</span>
  <span class="star" style="top:80px; left:50%; animation-delay: 2.5s;">✨</span>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    padding: 2rem 1rem;
    text-align: center;
    font-family: "Source Han Serif SC","Noto Serif SC","思源宋体",serif;
    font-style: italic;
    color: #444;
    background: linear-gradient(to right, #f8f8f8, #fafafa);
    border-top: 1px solid #ddd;
    position: relative;
    overflow: hidden;
  }
  .footer-content { max-width: 700px; margin: 0 auto; }

  .footer-quote {
    font-size: 1.1rem;
    margin-bottom: 0.8rem;
    color: #666;
    position: relative;
    display: inline-block;
    padding-bottom: 4px;
  }
  /* 🌈 流动的下划线 */
  .footer-quote::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    height: 2px;
    width: 100%;
    background: linear-gradient(90deg,#ff9a9e,#fad0c4,#fbc2eb,#a18cd1,#ff9a9e);
    background-size: 200% 100%;
    animation: underline-flow 4s linear infinite;
  }
  @keyframes underline-flow {
    0% { background-position: 0% 50%; }
    100% { background-position: 200% 50%; }
  }

  .footer-meta { font-size: 0.9rem; color: #999; margin: 1rem 0; }

  .back-to-top {
    font-size: 0.85rem;
    text-decoration: none;
    color: #555;
    border: 1px solid #aaa;
    padding: 4px 10px;
    border-radius: 10px;
    transition: all 0.3s ease;
  }
  .back-to-top:hover { background: #333; color: #fff; }

  /* ✨ 多个小星星动画 */
  .star {
    position: absolute;
    font-size: 1.2rem;
    color: #ffd700;
    opacity: 0.7;
    animation: twinkle 3s infinite alternate;
    pointer-events: none;
  }
  @keyframes twinkle {
    0% { opacity: 0.2; transform: scale(0.8); }
    100% { opacity: 1; transform: scale(1.2); }
  }
</style>

<script>
  // 返回顶部（平滑滚动）
  document.addEventListener('click', function(e){
    const link = e.target.closest('.back-to-top');
    if(link){
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });
</script>
