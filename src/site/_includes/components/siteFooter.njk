<style>
/* 固定底部 footer，只包含 GIF */
.fixed-footer {
  position: fixed;
  bottom: 0;
  right: 10px;
  z-index: 1000;
  pointer-events: auto;
}

/* 小猫 GIF 样式 */
.cat-gif {
  max-height: 80px;
  object-fit: contain;
  animation: float 2s ease-in-out infinite;
}

/* 浮动动画 */
@keyframes float {
  0%, 100% { transform: translateY(0px); }
