{# src/site/_includes/components/siteFooter.njk #}
<footer class="fixed-footer">
  <div class="footer-content">
    <img src="site/img/user/catwave.gif" alt="动态小猫" class="cat-gif">
  </div>
</footer>

<style>
html, body {
  margin: 0;
  padding: 0;
  height: 100%;
}

body {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* 主体撑满剩余空间 */
main {
  flex: 1 0 auto;
}

/* 固定底部 footer */
.fixed-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 80px; /* 可根据gif大小调整 */
  z-index: 1000;
  background: transparent;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 0 20px;
  pointer-events: auto;
}

/* 小猫 GIF 样式 */
.cat-gif {
  height: 60px; /* 根据需要调整大小 */
  width: auto;
  animation: float 2s ease-in-out infinite;
}

/* 悬浮动画 */
@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-5px); }
}

/* 移动端适配 */
@media (max-width: 768px) {
  .fixed-footer {
    height: 60px;
    padding: 0 10px;
  }
  .cat-gif {
    height: 40px;
  }
}
</style>
