{# src/site/_includes/components/siteFooter.njk #}
<footer class="fixed-footer">
  <div class="footer-content">
    <img src="https://res.cloudinary.com/ddirafvdx/image/upload/v1755694078/catwave_y2dya0.gif" alt="动态小猫" class="cat-gif">
  </div>
</footer>

<style>
html, body {
  margin: 0;
  padding: 0;
  height: 100%;
}

body {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* 主体撑满剩余空间 */
main {
  flex: 1 0 auto;
}

/* 固定底部 footer */
.fixed-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100px; /* 足够放 GIF */
  z-index: 1000;
  background: transparent;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 0 20px;
  pointer-events: auto;
}

/* 小猫 GIF 样式 */
.cat-gif {
  max-height: 80px; /* 保持比例，不超出 footer */
  max-width: 100%;
  object-fit: contain; /* 保持原始比例 */
  animation: float 2s ease-in-out infinite;
}

/* 浮动动画 */
@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-5px); }
}

/* 移动端适配 */
@media (max-width: 768px) {
  .fixed-footer {
    height: 70px;
    padding: 0 10px;
  }
  .cat-gif {
    max-height: 50px;
  }
}
</style>
