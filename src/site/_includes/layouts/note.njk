---
permalink: "notes/{{ page.fileSlug | slugify }}/"
---
<!DOCTYPE html>
<html lang="{{ meta.mainLanguage }}">
  <head>
    <title>{% if title %}{{ title }}{% else %}{{ page.fileSlug }}{% endif %}</title>
    {% include "components/pageheader.njk" %}
  </head>
  <body class="theme-{{meta.baseTheme}} markdown-preview-view markdown-rendered markdown-preview-section {{meta.bodyClasses}}">
    
    {% include "components/notegrowthhistory.njk" %}
    {% include "components/navbar.njk" %}

    <main class="content cm-s-obsidian {{contentClasses}}">
      {{ content | hideDataview | taggify | link | safe }}

      {# ------------------- 上下篇导航 ------------------- #}

      {# 假数据，模拟左侧目录顺序 #}
      {% set allNotes = [
        {fileSlug: 'note-1', permalink: '/notes/note-1/', title: '笔记一'},
        {fileSlug: 'note-2', permalink: '/notes/note-2/', title: '笔记二'},
        {fileSlug: 'note-3', permalink: '/notes/note-3/', title: '笔记三'}
      ] %}

      {# 找到当前笔记在目录中的索引 #}
      {% set index = allNotes | findIndex(note => note.fileSlug == page.fileSlug) %}

      {# 获取上一篇 / 下一篇 #}
      {% set previousNote = index > 0 ? allNotes[index - 1] : null %}
      {% set nextNote = index < allNotes | length - 1 ? allNotes[index + 1] : null %}

      {# 渲染导航 #}
      {% if previousNote or nextNote %}
        <nav class="note-navigation">
          {% if previousNote %}
            <a href="{{ previousNote.permalink }}" class="prev-note">← 上一篇: {{ previousNote.title }}</a>
          {% else %}
            <span></span>
          {% endif %}
          {% if nextNote %}
            <a href="{{ nextNote.permalink }}" class="next-note">下一篇: {{ nextNote.title }} →</a>
          {% else %}
            <span></span>
          {% endif %}
        </nav>
      {% endif %}

    </main>

    <style>
      .note-navigation {
        display: flex;
        justify-content: space-between;
        margin: 2rem 0;
        padding: 1rem;
        border-top: 1px solid #eee;
        border-bottom: 1px solid #eee;
      }
      .note-navigation a {
        text-decoration: none;
        color: #0077cc;
        font-weight: 500;
      }
      .note-navigation a:hover {
        text-decoration: underline;
      }
    </style>

  </body>
</html>
