---
permalink: /searchIndex.json
eleventyExcludeFromCollections: true
---
[
{% for post in collections.note %}
  {% set rawContent = post.templateContent | striptags(true) | trim %}
  {% set truncated = rawContent | slice(0, 100) | trim %}

  {% if rawContent | length > truncated | length %}
    {% set truncated = truncated ~ "…" %}
  {% endif %}

  {
    "title": {{ (post.data.title or post.fileSlug) | jsonify | safe }},
    "date": "{{ post.date }}",
    "url": "{{ post.url }}",
    "content": {{ truncated | link | jsonify | safe }},
    "tags": [
      {% set tags = [] %}
      {% set tags = tags.concat(post.templateContent | link | searchableTags | safe | split(",")) %}
      {% if post.data.tags %}
        {% set tags = tags.concat(post.data.tags) %}
      {% endif %}
      {% set tags = tags | reject("equalto", "") %}
      {% for tag in tags %}
        "{{ tag | validJson }}" {% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }{% if not loop.last %},{% endif %}
{% endfor %}
]
