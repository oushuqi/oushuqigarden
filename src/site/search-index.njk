---
permalink: /searchIndex.json
eleventyExcludeFromCollections: true
---
[
{% for post in collections.note %}
  {% set rawContent = post.templateContent | striptags(true) %}
  {% set truncated = rawContent | slice(0, 100) %}

  {# 智能截断：避免单词断开 #}
  {% set lastSpace = truncated.rfind(' ') %}
  {% if lastSpace > 50 %}
    {% set truncated = truncated | slice(0, lastSpace) %}
  {% endif %}

  {
    "title": {{ (post.data.title or post.fileSlug) | jsonify | safe }},
    "date": "{{ post.date }}",
    "url": "{{ post.url }}",
    "content": {{ truncated | link | jsonify | safe }},
    "tags": [
      {% set tags = [] %}
      {% set tags = tags.concat(post.templateContent | link | searchableTags | safe | split(",")) %}
      {% if post.data.tags %}
        {% set tags = tags.concat(post.data.tags) %}
      {% endif %}
      {% set tags = tags | reject("equalto", "") %}  {# 去掉空标签 #}
      {% for tag in tags %}
        "{{ tag | validJson }}" {% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }{% if not loop.last %},{% endif %}
{% endfor %}
]
